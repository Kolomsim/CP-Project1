# backend/.env

# Общие настройки
APP_NAME=SmartCheck Недвижимость

# CORS — разрешённые адреса фронтенда
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Настройки сервера
HOST=0.0.0.0
PORT=8000
RELOAD=True

USE_MOCK_EXTERNAL_API=False

# JWT Auth
JWT_SECRET_KEY=smartcheck-jwt-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (локально через docker-compose)
DATABASE_URL=postgresql+asyncpg://smartcheck:smartcheck_secret@localhost:5432/smartcheck

# 2ГИС — карта окружения на deal_result
DGIS_API_KEY=522a3e6e-3d4b-4065-bd5f-8cf0660181fd 
DEFAULT_SEARCH_RADIUS=2000
USE_REDIS=False