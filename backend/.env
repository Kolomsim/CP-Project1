# backend/.env

# Общие настройки
APP_NAME=SmartCheck Недвижимость

# CORS — разрешённые адреса фронтенда
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Настройки сервера
HOST=0.0.0.0
PORT=8000
RELOAD=True

USE_MOCK_EXTERNAL_API=False

# JWT Auth
JWT_SECRET_KEY=smartcheck-jwt-secret-key-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (локально через docker-compose)
DATABASE_URL=postgresql+asyncpg://smartcheck:smartcheck_secret@localhost:5432/smartcheck

USE_REDIS=True
REDIS_URL=redis://localhost:6379/0

DGIS_API_KEY=5657adab-122c-4d37-b026-5364d35a9b25
DGIS_SEARCH_URL=https://catalog.api.2gis.com/3.0/items
DEFAULT_SEARCH_RADIUS=1000