# Copy to .env on PythonAnywhere and fill in real values.
# cp .env.example .env

APP_NAME=SmartCheck Недвижимость
APP_VERSION=1.0.0
DEBUG=False

# Comma-separated. Add your frontend origin(s).
CORS_ORIGINS=https://YOURUSERNAME.pythonanywhere.com,http://localhost:5173

# Postgres (PythonAnywhere free tier has no Postgres — use Neon/Supabase or PA paid).
# Format for async SQLAlchemy:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

USE_MOCK_EXTERNAL_API=False
USE_REDIS=False

HOST=0.0.0.0
PORT=8000
RELOAD=False
